import requests
import json
from bs4 import BeautifulSoup
import re
from datetime import datetime

OUTPUT_FILE = 'result.json'

MARKETS = [
    {"name": "Hongkong Pools", "url": "https://angkanet18.com/paito-harian/"},
]

def fetch_html(url):
    try:
        response = requests.get(url, timeout=15)
        return response.text
    except:
        return None

def extract_data(html):
    if not html:
        return None, []
    
    soup = BeautifulSoup(html, 'lxml')
    lines = soup.find_all('div', class_='paito-line')
    
    latest = None
    history = []
    
    for i, line in enumerate(lines):
        digits = line.find_all('span', class_='paito-digit')
        if digits:
            text = ''.join([d.get_text(strip=True) for d in digits])
            num = re.sub(r'\D', '', text)[:4]
            if len(num) == 4:
                if i == 0:
                    latest = num
                else:
                    if num not in history:
                        history.append(num)
    
    return latest, history[:20]

def main():
    data = {}
    for market in MARKETS:
        print(f"Fetching {market['name']}...")
        html = fetch_html(market['url'])
        latest, hist = extract_data(html)
        
        if latest:
            print(f"✅ Got: {latest}")
            data[market['name']] = {
                "latest_result": latest,
                "history": hist,
                "last_updated": str(datetime.now())
            }
        else:
            print("❌ Failed to extract")
            data[market['name']] = {
                "latest_result": None,
                "history": [],
                "last_updated": str(datetime.now())
            }
    
    with open(OUTPUT_FILE, 'w') as f:
        json.dump(data, f, indent=2)
    print("Saved to result.json")

if __name__ == "__main__":
    main()
